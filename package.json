{
  "name": "ai_manager",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w web\"",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w server && npm run build -w web",
    "build:server": "npm run build -w server",
    "build:web": "npm run build -w web",
    "test": "npx vitest run --config server/vitest.config.ts && npx vitest run --config web/vite.config.ts",
    "test:server": "npx vitest run --config server/vitest.config.ts",
    "test:web": "npx vitest run --config web/vite.config.ts",
    "test:e2e": "npx playwright test -c tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/multer": "^2.2.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "file-type": "^22.0.1",
    "multer": "^2.2.0",
    "sharp": "^0.35.3"
  }
}
