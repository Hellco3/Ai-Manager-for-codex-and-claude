# Anthropic API Key (required)
ANTHROPIC_API_KEY=

# Claude model for task decomposition (default: claude-opus-4-8)
DECOMPOSER_MODEL=claude-opus-4-8

# Claude model for subtask execution (default: claude-sonnet-5)
EXECUTOR_MODEL=claude-sonnet-5

# Codex CLI path (default: codex)
CODEX_CLI_PATH=codex

# Timeouts (milliseconds)
CODEX_TIMEOUT_MS=300000
TASK_TIMEOUT_MS=1800000

# Concurrency
MAX_CONCURRENT_SUBTASKS=5
MAX_RETRIES=3

# Server
PORT=3001
HOST=0.0.0.0
