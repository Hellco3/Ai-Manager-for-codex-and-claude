version = 2
entry_window = "main"

[windows]
# Claude remains the primary coding lane.
main = "executor:claude"

# Codex keeps design work in its own context.
design = "designer:codex"

# Codex performs independent reviews in a separate lane.
review = "reviewer:codex"

[ui.sidebar]
mode = "every_window"
width = "18%"
bottom_height = 18
agents_height = "50%"
comms_height = "15%"
tips_height = "35%"
comms_limit = 4
